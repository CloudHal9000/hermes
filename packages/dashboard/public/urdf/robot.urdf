<?xml version="1.0" encoding="utf-8"?>
<robot name="freebotics_description">

  <!-- BASE FOOTPRINT (somente referência, sem visual/collision) -->
  <link name="base_footprint"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- BASE_LINK (chassi) -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.031416 0.00034126 0.03777" rpy="0 0 0" />
      <mass value="74.94" />
      <inertia ixx="0.31094" ixy="-0.00020432" ixz="-0.0064285"
               iyy="0.42877" iyz="0.00043298" izz="0.62523" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://freebotics_description/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.42353 0.64706 0.27451 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://freebotics_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- FRONT FORK -->
  <link name="front_fork">
    <inertial>
      <origin xyz="-0.012374 -0.00085969 -0.014072" rpy="0 0 0" />
      <mass value="0.5"/>
      <inertia ixx="0.00049832" ixy="1.1607E-07" ixz="-4.9049E-05"
               iyy="0.00042535" iyz="-1.4187E-08" izz="0.00056355"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://freebotics_description/meshes/front_fork.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.64706 0.61961 0.58431 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://freebotics_description/meshes/front_fork.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_fork_j" type="continuous">
    <origin xyz="0.33029 -0.00232 -0.12324" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_fork"/>
    <axis xyz="0 0 1"/>
    <limit effort="5" velocity="5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- FRONT WHEEL -->
  <link name="front_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.36"/>
      <inertia ixx="0.0002479" ixy="2.3292E-15" ixz="-7.9385E-21"
               iyy="0.00041439" iyz="7.6637E-20" izz="0.0002479"/>
