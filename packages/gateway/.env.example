# MQTT Configuration
# Broker MQTT (EMQX recomendado para produção)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=rmf-gateway
MQTT_PASSWORD=change-me-in-production

# Database Configuration
# PostgreSQL (Prisma suporta também MySQL, SQLite, etc)
DATABASE_URL=postgresql://rmf_user:rmf_password@localhost:5432/rmf_db

# JWT Configuration
# Mude este valor em produção!
JWT_SECRET=your-super-secret-key-change-in-production

# NestJS Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
# Frontend web-RMF URL
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# EMQX Specifics (se usando EMQX)
# EMQX Dashboard: http://localhost:18083 (default: admin/public)
# EMQX API: http://localhost:8081
