  <!-- ==================== CÂMERAS (com links intermediários) ==================== -->

  <!-- FRONT CAMERA MOUNT -->
  <link name="front_camera_mount"/>
  <joint name="front_camera_mount_joint" type="fixed">
    <origin xyz="0.38059 -0.0020788 0.23668" rpy="0 0 0"/>
