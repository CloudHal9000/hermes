    <child link="front_lidar_link"/>
  </joint>

  <link name="rear_rp">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.20467"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
