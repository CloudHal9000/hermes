# ─── RMF API Server ──────────────────────────────────────────────────────────
# REST base URL for the open-RMF Fleet API Server
VITE_RMF_API_URL=http://localhost:8000

# WebSocket base URL (same host, ws:// scheme)
VITE_RMF_WS_URL=ws://localhost:8000

# JWT Bearer token for RMF API authentication.
# For development: obtain from the RMF server logs on startup (stub token).
# For production: issued by Keycloak — see docs/auth-spec.md §3.
# ⚠️  VITE_* variables are inlined into the compiled JS bundle.
#     See docs/auth-spec.md §5 for the security implications.
VITE_RMF_TOKEN=your-rmf-jwt-token-here

# ─── Legacy (rosbridge — deprecated in Phase 4) ───────────────────────────────
# IP of the single robot running rosbridge WebSocket server
VITE_ROBOT_IP=192.168.1.100

# Legacy Flask API URL (used by useFleetPolling until replaced by useFleetState)
VITE_API_URL=http://localhost:8000
