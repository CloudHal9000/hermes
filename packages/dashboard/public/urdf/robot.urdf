        <mesh filename="package://freebotics_description/meshes/front_wheel.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://freebotics_description/meshes/front_wheel.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_wheel_j" type="continuous">
    <origin xyz="-0.044955 0 -0.059863" rpy="0 0 0"/>
    <parent link="front_fork"/>
    <child link="front_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" velocity="5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

