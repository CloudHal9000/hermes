{
  "name": "hermes",
  "private": true,
  "version": "1.0.0",
  "description": "Hermes — Fleet Management System for AGVs",
  "scripts": {
    "dev": "pnpm --filter dashboard dev",
    "dev:gateway": "pnpm --filter gateway start:dev",
    "dev:all": "concurrently \"pnpm dev:gateway\" \"pnpm dev\"",
    "build": "pnpm --filter dashboard build",
    "build:gateway": "pnpm --filter gateway build",
    "lint": "pnpm --filter dashboard lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
